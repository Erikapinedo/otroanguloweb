{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/",                      "destination": "/otroanguloweb/index.html" },
    { "source": "/index",                 "destination": "/otroanguloweb/index.html" },
    { "source": "/about-me-erika-pinedo", "destination": "/otroanguloweb/about-me-erika-pinedo.html" },
    { "source": "/portfolio",             "destination": "/otroanguloweb/portfolio.html" },
    { "source": "/contact",               "destination": "/otroanguloweb/contact.html" },
    { "source": "/project-parrotfy",      "destination": "/otroanguloweb/project-parrotfy.html" },
    { "source": "/project-nico-seguros",  "destination": "/otroanguloweb/project-nico-seguros.html" },
    { "source": "/project-expediente",    "destination": "/otroanguloweb/project-expediente.html" },
    { "source": "/project-alessandri",    "destination": "/otroanguloweb/project-alessandri.html" },
    { "source": "/project-bluesphere",    "destination": "/otroanguloweb/project-bluesphere.html" },
    { "source": "/project-playersnap",    "destination": "/otroanguloweb/project-playersnap.html" },
    { "source": "/images/:path*",                          "destination": "/otroanguloweb/images/:path*" },
    { "source": "/components/:path*",                      "destination": "/otroanguloweb/components/:path*" },
    { "source": "/cdn.prod.website-files.com/:path*",      "destination": "/otroanguloweb/cdn.prod.website-files.com/:path*" },
    { "source": "/cdn.jsdelivr.net/:path*",                "destination": "/otroanguloweb/cdn.jsdelivr.net/:path*" },
    { "source": "/unpkg.com/:path*",                       "destination": "/otroanguloweb/unpkg.com/:path*" },
    { "source": "/fonts.googleapis.com/:path*",            "destination": "/otroanguloweb/fonts.googleapis.com/:path*" },
    { "source": "/robots.txt",                             "destination": "/otroanguloweb/robots.txt" },
    { "source": "/sitemap.xml",                            "destination": "/otroanguloweb/sitemap.xml" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/cdn.prod.website-files.com/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
